# QuestLog Environment Configuration Template
# Copy this file to '.env' and fill in your API keys.

# Memori Cloud API Key (Get a free developer key at https://app.memorilabs.ai)
MEMORI_API_KEY=your_memori_api_key_here

# Gemini API Key for the Dungeon Master LLM (Recommended Free Tier)
GEMINI_API_KEY=your_gemini_api_key_here

# OpenAI API Key for the Dungeon Master LLM (Alternative)
OPENAI_API_KEY=your_openai_api_key_here

# Optional: Host and Port Configuration
HOST=127.0.0.1
PORT=8000
